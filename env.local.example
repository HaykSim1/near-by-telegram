# Copy to ".env.local" in the project root (gitignored).
# Get URL + keys from Supabase Dashboard → Project Settings → API, or Supabase MCP:
#   get_project_url, get_publishable_keys (use legacy "anon" JWT for VITE_SUPABASE_ANON_KEY).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-jwt-or-publishable-key
VITE_SUPABASE_FUNCTIONS_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1

# Browser dev without Telegram: create the same email in Dashboard → Authentication
VITE_DEV_AUTH_BYPASS=true
VITE_DEV_EMAIL=dev@nearby.local
VITE_DEV_PASSWORD=your-user-password

# console.info for auth bootstrap (safe fields only)
VITE_DEV_DEBUG=true
