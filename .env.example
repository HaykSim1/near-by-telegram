# Copy to `.env` for local dev. For Vercel/hosting, set these in the project
# environment and redeploy — Vite inlines `VITE_*` at build time.

# Shared feed + user settings (omit both to stay localStorage-only for activities)
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Demo seed data: omit = demo only in `npm run dev`; true/false to force
# VITE_USE_DEMO_DATA=true
