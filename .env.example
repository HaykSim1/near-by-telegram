# Supabase (public anon key — safe in Mini App bundle)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: Edge Function name (default: telegram-auth)
VITE_SUPABASE_FUNCTIONS_URL=https://your-project.supabase.co/functions/v1

# Local dev only: skip Telegram auth and use a fixed test session (requires matching user in Supabase)
# VITE_DEV_AUTH_BYPASS=true
# VITE_DEV_EMAIL=test@example.com
# VITE_DEV_PASSWORD=your-password
